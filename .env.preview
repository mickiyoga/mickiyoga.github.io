ENVIRONMENT="preview"

# Client's Formspree ID (email address)
PUBLIC_FORMSPREE_ID=info@micki.yoga

# FormSubmit.co target — email address or (preferred) the random hash
PUBLIC_CONTACT_FORM_ID=your-formsubmit-hash

# sessionStorage key base. The current route's pathname is appended
# automatically so forms on different pages don't collide.
PUBLIC_CONTACT_FORM_STORAGE_KEY=contact-form:pending
